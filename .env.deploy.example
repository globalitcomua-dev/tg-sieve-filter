TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_INTERVAL=5
TELEGRAM_BOT_NAME=sieve-filter
TELEGRAM_DROP_PENDING_UPDATES_ON_START=true

STATE_DB_PATH=./data/state.sqlite3
FILTER_STORAGE_BACKEND=mailcow_db
SIEVE_SCRIPT_PATH=./data/active.sieve
AUTO_APPLY=true
ALLOW_DUPLICATE_RULES=false

# Example: mailcowdockerized_mailcow-network
MAILCOW_DOCKER_NETWORK=

# Use the Mailcow DB hostname that is reachable inside the Mailcow Docker network.
# Often this is the MariaDB service/container name, not 127.0.0.1.
MAILCOW_DB_HOST=
MAILCOW_DB_PORT=3306
MAILCOW_DB_NAME=mailcow
MAILCOW_DB_USER=
MAILCOW_DB_PASSWORD=

MAILCOW_FILTER_USERNAME=info@nexus.ua
MAILCOW_FILTER_TYPE=postfilter
MAILCOW_FILTER_NAME=active
MAILCOW_FILTER_DESC=Auto-maintained postfilter

IMAP_VALIDATE_MAILBOX=false
IMAP_DEFAULT_PORT=993
IMAP_USE_SSL=true
IMAP_PASSWORD=
IMAP_PASSWORDS_JSON={}

RULE_COMMENT_PREFIX=# rule:
